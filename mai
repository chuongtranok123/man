<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title> Mân Macro đời thường — Trang cá nhân</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://i.imgur.com/Pp6o6rP.jpeg" rel="stylesheet">
<style>
  :root{
    --ink:#0F1B1A;
    --card:#16302C;
    --card-2:#1D3B35;
    --gold:#C9A227;
    --teal:#3F8E7C;
    --text:#EDE6D6;
    --muted:#8FA39C;
    --line:rgba(237,230,214,0.14);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--ink);
    color:var(--text);
    font-family:'Manrope', sans-serif;
    line-height:1.6;
    min-height:100vh;
    overflow-x:hidden;
    position:relative;
  }
  h1,h2,h3{font-family:'Fraunces', serif; font-weight:600; letter-spacing:-0.01em;}

  /* ================= NỀN ĐỘNG (blob gradient trôi nhẹ) ================= */
  .bg-blob{
    position:fixed;
    border-radius:50%;
    filter:blur(90px);
    opacity:0.35;
    z-index:0;
    pointer-events:none;
  }
  .bg-blob.b1{
    width:420px; height:420px;
    top:-120px; left:-100px;
    background:var(--teal);
    animation:float1 16s ease-in-out infinite;
  }
  .bg-blob.b2{
    width:360px; height:360px;
    bottom:-100px; right:-80px;
    background:var(--gold);
    opacity:0.18;
    animation:float2 20s ease-in-out infinite;
  }
  .bg-blob.b3{
    width:280px; height:280px;
    top:40%; left:60%;
    background:var(--card-2);
    opacity:0.3;
    animation:float3 22s ease-in-out infinite;
  }
  @keyframes float1{
    0%,100%{transform:translate(0,0) scale(1);}
    50%{transform:translate(60px,80px) scale(1.15);}
  }
  @keyframes float2{
    0%,100%{transform:translate(0,0) scale(1);}
    50%{transform:translate(-50px,-60px) scale(1.1);}
  }
  @keyframes float3{
    0%,100%{transform:translate(0,0);}
    50%{transform:translate(-70px,40px);}
  }
  @media (prefers-reduced-motion: reduce){
    .bg-blob{animation:none !important;}
  }

  /* Đưa toàn bộ nội dung lên trên lớp nền */
  .hero, .section, footer, #ad-container{position:relative; z-index:1;}

  /* ================= HERO ================= */
  .hero{
    max-width:920px;
    margin:0 auto;
    padding:90px 24px 60px;
    display:flex;
    gap:40px;
    align-items:center;
    flex-wrap:wrap;
  }
  .avatar{
    width:150px;
    height:150px;
    border-radius:50%;
    background:linear-gradient(145deg, var(--teal), var(--card-2));
    border:2px solid var(--gold);
    flex-shrink:0;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Fraunces', serif;
    font-size:52px;
    color:var(--gold);
    box-shadow:0 0 0 6px rgba(201,162,39,0.08);
    animation:pop-in .6s cubic-bezier(.34,1.56,.64,1) both, glow-pulse 4s ease-in-out 1s infinite;
    /* Thay bằng: background-image:url('duong-dan-anh-cua-ban.jpg'); background-size:cover; background-position:center; */
  }
  @keyframes pop-in{
    from{opacity:0; transform:scale(.7);}
    to{opacity:1; transform:scale(1);}
  }
  @keyframes glow-pulse{
    0%,100%{box-shadow:0 0 0 6px rgba(201,162,39,0.08);}
    50%{box-shadow:0 0 0 12px rgba(201,162,39,0.14);}
  }
  .hero-text{flex:1; min-width:260px;}
  .hero-text .eyebrow{animation:fade-up .6s ease .1s both;}
  .hero-text h1{animation:fade-up .6s ease .22s both;}
  .hero-text p{animation:fade-up .6s ease .34s both;}
  @keyframes fade-up{
    from{opacity:0; transform:translateY(14px);}
    to{opacity:1; transform:translateY(0);}
  }
  .eyebrow{
    color:var(--gold);
    font-size:13px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:10px;
  }
  .hero-text h1{font-size:clamp(32px,5vw,48px); margin-bottom:12px;}
  .hero-text p{color:var(--muted); font-size:17px; max-width:520px;}

  /* ================= SCROLL REVEAL ================= */
  .reveal{
    opacity:0;
    transform:translateY(24px);
    transition:opacity .7s ease, transform .7s ease;
  }
  .reveal.in-view{
    opacity:1;
    transform:translateY(0);
  }
  @media (prefers-reduced-motion: reduce){
    .reveal{opacity:1; transform:none; transition:none;}
    .avatar{animation:none;}
    .hero-text .eyebrow, .hero-text h1, .hero-text p{animation:none;}
  }

  /* ================= SECTION LABEL ================= */
  .section{max-width:920px; margin:0 auto; padding:40px 24px;}
  .section-title{
    display:flex;
    align-items:center;
    gap:14px;
    margin-bottom:26px;
  }
  .section-title span{
    font-size:12px;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--muted);
    white-space:nowrap;
  }
  .section-title::after{
    content:"";
    height:1px;
    width:100%;
    background:var(--line);
  }

  /* ================= SOCIAL LINKS ================= */
  .social-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(220px,1fr));
    gap:14px;
  }
  .social-card{
    position:relative;
    display:flex;
    align-items:center;
    gap:14px;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:12px;
    padding:16px 18px;
    text-decoration:none;
    color:var(--text);
    overflow:hidden;
    transition:transform .22s ease, border-color .22s ease, background .22s ease, box-shadow .22s ease;
  }
  .social-card::before{
    content:"";
    position:absolute;
    inset:0;
    background:radial-gradient(180px circle at var(--mx,50%) var(--my,50%), rgba(201,162,39,0.16), transparent 70%);
    opacity:0;
    transition:opacity .25s ease;
    pointer-events:none;
  }
  .social-card:hover::before{opacity:1;}
  .social-card:hover{
    transform:translateY(-4px);
    border-color:var(--gold);
    background:var(--card-2);
    box-shadow:0 10px 24px rgba(0,0,0,0.35);
  }
  .social-card:hover .social-icon{
    transform:scale(1.12) rotate(-4deg);
  }
  .social-icon{
    width:38px; height:38px;
    border-radius:9px;
    background:var(--card-2);
    display:flex; align-items:center; justify-content:center;
    font-size:19px;
    flex-shrink:0;
    transition:transform .25s cubic-bezier(.34,1.56,.64,1);
  }
  .social-name{font-weight:700; font-size:15px;}
  .social-handle{font-size:13px; color:var(--muted);}

  /* ================= ABOUT / BIO ================= */
  .about-box{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:14px;
    padding:26px 28px;
    color:var(--muted);
    font-size:15.5px;
  }
  .about-box strong{color:var(--text);}

  footer{
    text-align:center;
    padding:50px 24px 140px;
    color:var(--muted);
    font-size:13px;
  }

  /* ================= AD BANNERS (góc dưới) ================= */
  #ad-container{
    position:fixed;
    right:18px;
    bottom:18px;
    display:flex;
    flex-direction:column-reverse;
    gap:10px;
    z-index:999;
    max-width:280px;
  }
  .ad-banner{
    position:relative;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 8px 24px rgba(0,0,0,0.45);
    border:1px solid var(--line);
    background:var(--card);
    animation:ad-in .35s ease both;
  }
  @keyframes ad-in{
    from{opacity:0; transform:translateY(14px);}
    to{opacity:1; transform:translateY(0);}
  }
  .ad-banner a{display:block; line-height:0;}
  .ad-banner img{
    width:100%;
    display:block;
    object-fit:cover;
  }
  .ad-label{
    position:absolute;
    top:6px;
    left:6px;
    background:rgba(0,0,0,0.55);
    color:#fff;
    font-size:9px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:2px 6px;
    border-radius:4px;
    pointer-events:none;
  }
  .ad-close{
    position:absolute;
    top:6px;
    right:6px;
    width:20px;
    height:20px;
    border-radius:50%;
    background:rgba(0,0,0,0.55);
    color:#fff;
    border:none;
    font-size:13px;
    line-height:1;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .ad-close:hover{background:rgba(0,0,0,0.8);}

  @media (max-width:520px){
    #ad-container{right:10px; bottom:10px; max-width:200px;}
    .hero{padding-top:60px;}
  }

  /* ================= TOAST (thông báo khi link ẩn được kích hoạt) ================= */
  #interstitial-toast{
    position:fixed;
    left:50%;
    top:24px;
    transform:translate(-50%,-140%);
    background:var(--card-2);
    border:1px solid var(--gold);
    color:var(--text);
    padding:12px 20px;
    border-radius:10px;
    font-size:13.5px;
    box-shadow:0 10px 30px rgba(0,0,0,0.5);
    z-index:1200;
    display:flex;
    align-items:center;
    gap:10px;
    transition:transform .35s cubic-bezier(.34,1.56,.64,1);
    max-width:90vw;
    text-align:center;
  }
  #interstitial-toast.show{transform:translate(-50%,0);}
  #interstitial-toast .dot{
    width:8px; height:8px;
    border-radius:50%;
    background:var(--gold);
    flex-shrink:0;
    animation:dot-pulse 1s ease-in-out infinite;
  }
  @keyframes dot-pulse{
    0%,100%{opacity:0.4; transform:scale(0.8);}
    50%{opacity:1; transform:scale(1.2);}
  }
</style>
</head>
<body>

  <!-- Nền động, chỉ để trang trí, không ảnh hưởng nội dung -->
  <div class="bg-blob b1"></div>
  <div class="bg-blob b2"></div>
  <div class="bg-blob b3"></div>

  <!-- Toast thông báo khi link ẩn quảng cáo được kích hoạt lần đầu -->
  <div id="interstitial-toast"><span class="dot"></span><span id="interstitial-toast-text">Đang mở nội dung tài trợ…</span></div>

  <!-- ============ HERO / GIỚI THIỆU ============ -->
  <section class="hero">
    <div class="avatar">A</div>
    <!-- Đổi chữ "A" ở trên hoặc dùng ảnh: mở comment trong CSS .avatar -->
    <div class="hero-text">
      <div class="eyebrow">Xin chào, tôi là</div>
      <h1>Mân macro đời thường</h1>
      <p>mân chuyên bóc phét , và hiện tại là chủ 1 quán sửa điện thoại kiêm luôn bán điện thoại, anh ta rất nóng tính, kh nên chọc Mân macro đời thường!</p>
    </div>
  </section>

  <!-- ============ GIỚI THIỆU CHI TIẾT ============ -->
  <section class="section reveal">
    <div class="section-title"><span>Giới thiệu</span></div>
    <div class="about-box">
      Đây là nơi bạn viết mô tả ngắn về bản thân: <strong>mân macro đời thường</strong>, <strong>chủ quán sửa điện thoại</strong>,
      và <strong>nuộc</strong> với người xem trang này. Hãy thay đoạn văn này bằng nội dung thật của bạn.
    </div>
  </section>

  <!-- ============ MẠNG XÃ HỘI ============ -->
  <section class="section reveal">
    <div class="section-title"><span>Mạng xã hội</span></div>
    <div class="social-grid" id="social-grid"></div>
  </section>

  <footer>
    © <span id="year"></span> Mai Ca. Made with ♥
  </footer>

  <!-- ============ VÙNG CHỨA BANNER QUẢNG CÁO (góc dưới bên phải) ============ -->
  <div id="ad-container"></div>

<script>
/* =========================================================================
   1) DANH SÁCH MẠNG XÃ HỘI
   Thêm / xoá / sửa các mục trong mảng bên dưới.
   icon: có thể dùng emoji hoặc để trống dùng chữ cái đầu
   ========================================================================= */
const SOCIAL_LINKS = [
  { name: "Facebook",  handle: "MAicon",  icon: "📘", url: "https://www.facebook.com/man.marco.979932?locale=vi_VN" },
  { name: "Instagram", handle: "@nguyenvana",  icon: "📸", url: "https://instagram.com/yourpage" },
  { name: "TikTok",    handle: "Maicon",  icon: "🎵", url: "https://www.tiktok.com/@manmarco305" },
  { name: "YouTube",   handle: "Kênh của tôi", icon: "▶️", url: "https://youtube.com/@yourchannel" },
  { name: "Zalo",      handle: "090xxxxxxx",   icon: "💬", url: "https://zalo.me/yourphone" },
  { name: "Email",     handle: "you@email.com",icon: "✉️", url: "mailto:you@email.com" },
];

function renderSocial(){
  const grid = document.getElementById("social-grid");
  grid.innerHTML = SOCIAL_LINKS.map(s => `
    <a class="social-card" href="${s.url}" target="_blank" rel="noopener noreferrer">
      <div class="social-icon">${s.icon || s.name.charAt(0)}</div>
      <div>
        <div class="social-name">${s.name}</div>
        <div class="social-handle">${s.handle}</div>
      </div>
    </a>
  `).join("");
}
renderSocial();

/* =========================================================================
   2) BANNER QUẢNG CÁO — góc dưới bên phải
   Thêm bao nhiêu banner tuỳ thích bằng cách thêm object vào mảng AD_BANNERS.
   - image : đường dẫn / URL hình ảnh banner
   - link  : link ẩn trong ảnh, khi bấm vào ảnh sẽ mở link này (tab mới)
   - alt   : mô tả ảnh (SEO / trợ năng)
   - width : chiều rộng hiển thị (px), mặc định 260
   - showLabel : hiện nhãn "Quảng cáo" ở góc ảnh (true/false)
   ========================================================================= */
const AD_BANNERS = [
  {
    image: "https://via.placeholder.com/260x120/1D3B35/C9A227?text=Qu%E1%BA%A3ng+c%C3%A1o+1",
    link: "https://example.com/link-quang-cao-1",
    alt: "Mai",
    width: 260,
    showLabel: true
  },
  {
    image: "https://via.placeholder.com/260x120/16302C/EDE6D6?text=Qu%E1%BA%A3ng+c%C3%A1o+2",
    link: "https://example.com/link-quang-cao-2",
    alt: "CA",
    width: 260,
    showLabel: true
  }
  // 👉 Thêm banner mới ở đây, chỉ cần copy 1 object bên trên và đổi image / link
];

function renderAds(){
  const container = document.getElementById("ad-container");
  container.innerHTML = "";
  AD_BANNERS.forEach((ad, i) => {
    const wrap = document.createElement("div");
    wrap.className = "ad-banner";
    wrap.style.width = (ad.width || 260) + "px";
    wrap.dataset.index = i;

    wrap.innerHTML = `
      ${ad.showLabel !== false ? '<span class="ad-label">Quảng cáo</span>' : ''}
      <button class="ad-close" aria-label="Đóng quảng cáo" onclick="this.parentElement.remove()">✕</button>
      <a href="${ad.link}" target="_blank" rel="noopener sponsored noreferrer">
        <img src="${ad.image}" alt="${ad.alt || 'Quảng cáo'}" loading="lazy">
      </a>
    `;
    container.appendChild(wrap);
  });
}
renderAds();

document.getElementById("year").textContent = new Date().getFullYear();

/* =========================================================================
   3) LINK ẨN TOÀN MÀN HÌNH — kích hoạt ở LẦN BẤM ĐẦU TIÊN
   Cách hoạt động:
   - Lần bấm đầu tiên vào BẤT KỲ liên kết nào trên trang (vd: Facebook)
     sẽ bị chặn lại, mở link quảng cáo ở ẢNG_LINK.url trong tab mới,
     đồng thời hiện toast thông báo cho người xem biết.
   - Từ lần bấm thứ 2 trở đi, mọi liên kết hoạt động bình thường
     (được ghi nhớ bằng sessionStorage nên chỉ hỏi lại nếu mở tab mới).
   - Muốn tắt tính năng này: đặt enabled = false.
   ========================================================================= */
const INTERSTITIAL_AD = {
  enabled: true,
  url: "https://www.tiktok.com/@yeunhatponn/video/7577641742212599060?is_from_webapp=1&sender_device=pc",     // link ẩn sẽ mở ở lần bấm đầu tiên
  toastText: "Đang mở nội dung tài trợ… bạn có thể bấm lại liên kết để tiếp tục.",
  storageKey: "interstitial_shown"
};

function showToast(text){
  const toast = document.getElementById("interstitial-toast");
  document.getElementById("interstitial-toast-text").textContent = text;
  toast.classList.add("show");
  clearTimeout(showToast._t);
  showToast._t = setTimeout(() => toast.classList.remove("show"), 3200);
}

function initInterstitial(){
  if(!INTERSTITIAL_AD.enabled) return;

  document.addEventListener("click", function(e){
    // Đã kích hoạt trong phiên này rồi -> để link chạy bình thường
    if(sessionStorage.getItem(INTERSTITIAL_AD.storageKey)) return;

    // Tìm thẻ <a> gần nhất chứa liên kết thật (bỏ qua nút đóng banner, v.v.)
    const link = e.target.closest("a[href]");
    if(!link) return;

    // Không áp dụng cho chính banner quảng cáo (đã có link quảng cáo riêng)
    if(link.closest("#ad-container")) return;

    // Chặn điều hướng gốc ở lần bấm đầu tiên
    e.preventDefault();
    sessionStorage.setItem(INTERSTITIAL_AD.storageKey, "1");

    // Mở link quảng cáo ẩn ở tab mới
    window.open(INTERSTITIAL_AD.url, "_blank", "noopener,noreferrer");

    // Thông báo nhẹ cho người dùng
    showToast(INTERSTITIAL_AD.toastText);

    // Lưu lại link người dùng thực sự muốn bấm, để họ bấm lại là đi luôn
    link.dataset.pendingDestination = link.href;
  }, true); // dùng capture phase để chặn trước mọi xử lý khác
}
initInterstitial();

/* =========================================================================
   4) HIỆU ỨNG CON TRỎ PHÁT SÁNG TRÊN SOCIAL CARD
   ========================================================================= */
document.addEventListener("mousemove", (e) => {
  const card = e.target.closest && e.target.closest(".social-card");
  if(!card) return;
  const rect = card.getBoundingClientRect();
  card.style.setProperty("--mx", (e.clientX - rect.left) + "px");
  card.style.setProperty("--my", (e.clientY - rect.top) + "px");
});

/* =========================================================================
   5) SCROLL REVEAL — các section mờ dần hiện ra khi cuộn tới
   ========================================================================= */
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      entry.target.classList.add("in-view");
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.15 });

document.querySelectorAll(".reveal").forEach(el => revealObserver.observe(el));
</script>
</body>
</html>
